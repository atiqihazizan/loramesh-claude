# Digunakan semasa `npm run build` sahaja (Vite mode production).
# Dev kekal guna frontend/.env (localhost:5002).

VITE_APP_BASE=/v2/

# Kosong = same-origin /v2/api dan path socket /v2/socket.io (cloud + legacy v1)
VITE_API_URL=
VITE_SOCKET_URL=

# Mesti selari backend/APK legacy jika guna QR verify
VITE_PROVISION_ENCRYPTION_KEY=da9dece0aeefdc38f021d7cee0356e9f8
