# Path UI (Vite base): '/' atau '/v2/' — mesti ada slash hujung atau '/' sahaja
VITE_APP_BASE=/v2/

# Dev backend (PORT 5002). Jangan letak /v2/ pada URL API.
VITE_API_URL=http://localhost:5002
VITE_SOCKET_URL=http://localhost:5002

# Production build: salin ke `.env.production` (commit OK — tiada secret).
# Fail `.env.production` sudah wujud dalam repo; `npm run build` guna itu, bukan localhost di `.env`.

# Legacy QR encrypt (mesti sama dengan lora2u_nodejs PROVISION_ENCRYPTION_KEY / APK verify)
VITE_PROVISION_ENCRYPTION_KEY=default-32-char-encryption-key!!
