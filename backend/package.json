{
  "name": "backend-claude",
  "version": "3.0.0",
  "description": "LoRa Mesh Tracking API — claude rewrite",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "migrate:from-legacy": "node scripts/migrate-from-legacy.js",
    "migrate:playback-tables": "node scripts/migrate-playback-tables.js",
    "verify-data": "node scripts/verify-data.js",
    "seed:pilot": "node scripts/seed-pilot-data.js",
    "retention:metadata": "node jobs/retention-manager.js metadata",
    "retention:archive": "node jobs/retention-manager.js archive",
    "retention:purge": "node jobs/retention-manager.js purge"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mariadb": "^3.5.2",
    "morgan": "^1.10.0",
    "mqtt": "^5.14.1",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^7.8.0"
  }
}
