# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# cp .env.example .env
# ====================================
# backend_claude — environment template
# Copy to .env and fill in. Never commit .env
# ====================================

# --- Server ---
NODE_ENV=development
PORT=5002
TIMEZONE=Asia/Kuala_Lumpur

# --- Database (single unified DB) ---
DATABASE_URL=mysql://root:root@localhost:3306/lora_mesh_pro

# --- Auth ---
# Frontend JWT
JWT_SECRET=ffBVGIVSDKWJYl7/JrTs3zgu936HPxNzo0oqNQju9yyKyuyl67f5rAXNHI4+pisR
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Socket.IO ---
# false = device-tracking with filter/threshold (production)
# true  = device-tracking-raw without filter (debug only)
USE_RAW_TRACKING=false
TRACKING_EMIT_VERBOSE=false

# --- MQTT (Flutter modbus_go + LoRa Node-Red) ---
MQTT_ENABLED=true
MQTT_HOST=178.128.48.114
MQTT_PORT=8885
MQTT_PROTOCOL=ws
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT WSS (untuk frontend HTTPS)
MQTT_WSS_HOST=178.128.48.114
MQTT_WSS_PORT=8887

# MQTT tuning
MQTT_PROCESS_CONCURRENCY=8
MQTT_SUBSCRIBE_QOS=2
MQTT_MODBUS_SUBSCRIBE_QOS=1
MQTT_DEVICE_UPDATE_MIN_MS=0
MQTT_LOG_INCOMING_DB=true
MQTT_VERBOSE_LOG=false

# --- Heartbeat (device offline detection) ---
MODBUSGO_HEARTBEAT_TIMEOUT=60000
LORA_HEARTBEAT_TIMEOUT=120000

# --- Internal API base URL (MQTT handler → REST self-call) ---
API_BASE_URL=http://localhost:5002

# --- Provisioning ---
# Nonce time-to-live in minutes (default: 1 day)
PROVISIONING_NONCE_TTL_MIN=1440
PROVISION_ENCRYPTION_KEY=da9dece0aeefdc38f021d7cee0356e9f8
# --- Rate limit ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000